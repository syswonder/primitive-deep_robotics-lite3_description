     For more information, please see http://wiki.ros.org/sw_urdf_exporter -->
<robot name="Lite3">
    <mujoco>
        <compiler meshdir="../meshes/" balanceinertia="false" discardvisual="false" fusestatic="false"/>
    </mujoco>

    <!-- base_link: 机体质心根坐标系（ROS 标准约定） -->
    <link name="base_link"/>

    <!-- 固定关节：base_link → TORSO（与机器人运动板 odom 坐标对齐） -->
    <joint name="base_to_torso" type="fixed">
        <parent link="base_link"/>
        <child link="TORSO"/>
        <origin xyz="0 0 0" rpy="0 0 0"/>
    </joint>

    <link name="TORSO">
        <inertial>
            <origin/>
            <mass value="5.6056"/>
            <inertia ixx="0.02456" ixy="0" ixz="0" iyy="0.05518" iyz="0" izz="0.07016"/>
        </inertial>
        <visual>
            <geometry>
                <mesh filename="../meshes/torso.STL"/>
            </geometry>
        </visual>
        <collision>
            <origin xyz="0 0 0.01"/>
            <geometry>
                <box size="0.5 0.1 0.12"/>
            </geometry>
        </collision>
        <collision>
            <origin xyz="0 0 0.01"/>
            <geometry>
                <box size="0.25 0.2 0.12"/>
            </geometry>
        </collision>
    </link>

    <!-- ================================================================== -->
    <!-- UniLidar L2 LiDAR — mounted on top of TORSO                        -->
    <!-- ================================================================== -->
    <link name="unilidar_lidar">
        <inertial>
            <mass value="0.001"/>
            <inertia ixx="0.000001" ixy="0" ixz="0" iyy="0.000001" iyz="0" izz="0.000001"/>
        </inertial>
    </link>
    <joint name="base_to_unilidar" type="fixed">
        <parent link="TORSO"/>
        <child link="unilidar_lidar"/>
        <origin xyz="0 0 0.10" rpy="0 0 0"/>
    </joint>

    <!-- ================================================================== -->
    <!-- Livox MID-360 LiDAR — same mount position as UniLidar L2           -->
    <!-- ================================================================== -->
    <link name="livox_frame">
        <inertial>
            <mass value="0.001"/>
            <inertia ixx="0.000001" ixy="0" ixz="0" iyy="0.000001" iyz="0" izz="0.000001"/>
        </inertial>
    </link>
    <joint name="base_to_livox" type="fixed">
        <parent link="TORSO"/>
        <child link="livox_frame"/>
        <origin xyz="0 0 0.10" rpy="0 0 0"/>
    </joint>

    <!-- ================================================================== -->
    <!-- RealSense D435i Camera — mounted on front-top of TORSO             -->
    <!-- ================================================================== -->
    <link name="camera_bottom_screw_frame"/>

    <joint name="base_to_camera_mount" type="fixed">
        <parent link="TORSO"/>
        <child link="camera_bottom_screw_frame"/>
        <origin xyz="0.22 0 0.06" rpy="0 0 0"/>
    </joint>

    <!-- camera body link: origin at bottom screw mount per realsense convention -->
    <link name="camera_link">
        <visual>
            <origin xyz="0.015 0.0175 0.0125" rpy="0 0 0"/>
            <geometry>
                <box size="0.02505 0.090 0.025"/>
            </geometry>
            <material name="camera_body">
                <color rgba="0.3 0.3 0.3 1"/>
            </material>
        </visual>
        <collision>
            <origin xyz="0.015 0.0175 0.0125" rpy="0 0 0"/>
            <geometry>
                <box size="0.02505 0.090 0.025"/>
            </geometry>
        </collision>
        <inertial>
            <mass value="0.072"/>
            <origin xyz="0.015 0.0175 0.0125"/>
            <inertia ixx="0.003881" ixy="0" ixz="0" iyy="0.000499" iyz="0" izz="0.003879"/>
        </inertial>
    </link>

    <joint name="camera_mount_to_link" type="fixed">
        <parent link="camera_bottom_screw_frame"/>
        <child link="camera_link"/>
        <origin xyz="0.0148 0.0175 0.0125" rpy="0 0 0"/>
    </joint>

    <!-- depth frame: at the front glass of the camera -->
    <link name="camera_depth_frame"/>
    <joint name="camera_to_depth" type="fixed">
        <parent link="camera_link"/>
        <child link="camera_depth_frame"/>
        <origin xyz="0 0 0" rpy="0 0 0"/>
    </joint>

    <link name="camera_depth_optical_frame"/>
    <joint name="depth_to_depth_optical" type="fixed">
        <parent link="camera_depth_frame"/>
        <child link="camera_depth_optical_frame"/>
        <origin xyz="0 0 0" rpy="-1.5707963 0 -1.5707963"/>
    </joint>

    <!-- color frame: 15mm offset from depth -->
    <link name="camera_color_frame"/>
    <joint name="camera_to_color" type="fixed">
        <parent link="camera_link"/>
        <child link="camera_color_frame"/>
        <origin xyz="0 0.015 0" rpy="0 0 0"/>
